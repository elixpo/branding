{
  "name": "elixpo-mails-og",
  "description": "OG/social-card palette for Elixpo Mails — the light 'oreo' (Cohere/coral) system from mail.elixpo/app/globals.css. Editorial tech-minimalism; coral is the only saturated colour.",
  "canvas": { "width": 1200, "height": 630, "safeMargin": 60 },
  "colors": {
    "canvas": "#ffffff",
    "softCanvas": "#faf9f6",
    "ink": "#212121",
    "slate": "#75758a",
    "mutedSlate": "#93939f",
    "hairline": "#d9d9dd",
    "cardBorder": "#f2f2f2",
    "accent": "#ff7759",
    "accentSoft": "#ffad9b",
    "accentTint": "rgba(255,119,89,0.10)",
    "nearBlack": "#17171c",
    "softStone": "#eeece7",
    "actionBlue": "#1863dc"
  },
  "type": {
    "headline": {
      "family": "Fraunces, 'Playfair Display', Georgia, serif",
      "weight": 700,
      "style": "high-contrast serif",
      "color": "#212121",
      "capHeight": "96-120px"
    },
    "eyebrow": {
      "family": "'Space Mono', ui-monospace, monospace",
      "transform": "uppercase",
      "letterSpacing": "0.18em",
      "color": "#93939f"
    },
    "body": {
      "family": "Inter, ui-sans-serif, system-ui",
      "color": "#75758a"
    },
    "url": {
      "family": "'Space Mono', monospace",
      "transform": "lowercase",
      "color": "#93939f"
    }
  },
  "mascot": {
    "name": "Oreo",
    "render": "ONE continuous unbroken line (one-line / continuous-line drawing) suggesting the panda's facade, flowing into a horizon line; flat 2D, no closed shapes, no shading",
    "lineColor": "#212121",
    "lineWeight": "matches blueprint hairline",
    "colorPatch": { "fill": "#ff7759", "where": "a single filled ear", "note": "the ONLY colour on the mascot — stands in for Oreo's badge" }
  }
}
